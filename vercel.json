{
  "crons": [
    {
      "path": "/api/notifications/daily",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "app/api/essays/review/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
